root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.xml]
indent_size = 4

[*.json]
indent_size = 2

[{gradlew,gradlew.bat}]
end_of_line = unset

[*.bat]
end_of_line = crlf
